# Copy to .env and fill in for Sepolia deployment

# RPC URL for Sepolia (Alchemy, Infura, or any public provider)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_project_id

# Private key of the deployer (do NOT commit the real .env)
# Use a dedicated testnet wallet. Never use a mainnet key here.
PRIVATE_KEY=

# For contract verification on Etherscan
ETHERSCAN_API_KEY=
